<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btnHeaderBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:scaleType="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compare Tracks"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select two tracks"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btnDisconnect"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_disconnect"
            android:scaleType="fitCenter"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- State panels -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- BROWSE state -->
        <LinearLayout
            android:id="@+id/browsingPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvPath"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="/ root"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextSecondary" />

                <ProgressBar
                    android:id="@+id/browsingProgress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorSurface" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerFiles"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No tracks found"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- COMPARE state -->
        <LinearLayout
            android:id="@+id/comparePanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Track selection buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/btnSelectTrack1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_btn_action"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRACK 1"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="@color/colorChartHSpeed"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvTrack1Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Select track…"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextSecondary"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <ProgressBar
                        android:id="@+id/pbTrack1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:indeterminate="true"
                        android:visibility="gone" />

                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <LinearLayout
                    android:id="@+id/btnSelectTrack2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_btn_action"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRACK 2"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="@color/colorChartT2HSpeed"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvTrack2Name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Select track…"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextSecondary"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <ProgressBar
                        android:id="@+id/pbTrack2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:indeterminate="true"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Chart -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chartCard"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp"
                android:visibility="gone">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Values panel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/valuesPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <!-- Track 1 metrics row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <LinearLayout
                            android:id="@+id/colT1Elev"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ELEVATION"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT1ElevValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartElevation" />
                            <TextView
                                android:id="@+id/tvT1ElevUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="m"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/colT1HSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="H. SPEED"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT1HSpeedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartHSpeed" />
                            <TextView
                                android:id="@+id/tvT1HSpeedUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km/h"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/colT1VSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="V. SPEED"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT1VSpeedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartVSpeed" />
                            <TextView
                                android:id="@+id/tvT1VSpeedUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km/h"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/colT1Total"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT1TotalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartTotalSpeed" />
                            <TextView
                                android:id="@+id/tvT1TotalUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km/h"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@color/colorSurface" />

                    <!-- Track 2 metrics row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <LinearLayout
                            android:id="@+id/colT2Elev"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ELEVATION"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT2ElevValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartT2Elevation" />
                            <TextView
                                android:id="@+id/tvT2ElevUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="m"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/colT2HSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="H. SPEED"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT2HSpeedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartT2HSpeed" />
                            <TextView
                                android:id="@+id/tvT2HSpeedUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km/h"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/colT2VSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="V. SPEED"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT2VSpeedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartT2VSpeed" />
                            <TextView
                                android:id="@+id/tvT2VSpeedUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km/h"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/colT2Total"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackground"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextTertiary"
                                android:letterSpacing="0.05" />
                            <TextView
                                android:id="@+id/tvT2TotalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorChartT2TotalSpeed" />
                            <TextView
                                android:id="@+id/tvT2TotalUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km/h"
                                android:textSize="10sp"
                                android:textColor="@color/colorTextTertiary" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
