<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FlySight 2"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Manager"
            android:textSize="14sp"
            android:textColor="@color/colorTextSecondary" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MY DEVICES"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextTertiary"
                android:letterSpacing="0.1"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPaired"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvNoPaired"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No paired devices. Connect to a FlySight 2 to add it here."
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="13sp"
                        android:padding="16dp"
                        android:visibility="visible" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvSectionAddDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ADD NEW DEVICE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextTertiary"
                android:letterSpacing="0.1"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- IDLE: instruction hint + scan button -->
                    <LinearLayout
                        android:id="@+id/panelScanIdle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Turn off your FlySight and press the Power button twice to enter pairing mode. The green LED will start pulsing."
                            android:textSize="13sp"
                            android:textColor="@color/colorTextSecondary"
                            android:paddingBottom="14dp" />

                        <LinearLayout
                            android:id="@+id/btnScan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_btn_action"
                            android:padding="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:src="@drawable/ic_scan"
                                android:scaleType="fitCenter"
                                android:layout_marginEnd="12dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvBtnScanLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Scan for devices"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/colorTextPrimary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Find FlySights in pairing mode"
                                    android:textSize="12sp"
                                    android:textColor="@color/colorTextSecondary" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- SCANNING: status row + thin progress bar + results -->
                    <LinearLayout
                        android:id="@+id/panelScanActive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:id="@+id/tvScanStatus"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Scanning for devices…"
                                android:textSize="13sp"
                                android:textColor="@color/colorTextSecondary" />

                            <TextView
                                android:id="@+id/tvScanCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorPrimary" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/colorPrimary"
                            android:visibility="visible" />

                        <TextView
                            android:id="@+id/tvEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No FlySight 2 devices found.\nMake sure the device is powered on."
                            android:textColor="@color/colorTextSecondary"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:visibility="gone" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                    <!-- CONNECTING: steps panel -->
                    <LinearLayout
                        android:id="@+id/panelConnecting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvConnectDevice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/colorTextSecondary"
                            android:paddingTop="12dp"
                            android:paddingBottom="10dp" />

                        <ProgressBar
                            android:id="@+id/progressBarConnect"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/colorDownload"
                            android:layout_marginStart="-16dp"
                            android:layout_marginEnd="-16dp" />

                        <TextView
                            android:id="@+id/tvStep1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Pairing handshake"
                            android:textSize="13sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/colorTextTertiary" />

                        <TextView
                            android:id="@+id/tvStep2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Authenticating"
                            android:textSize="13sp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/colorTextTertiary" />

                        <TextView
                            android:id="@+id/tvStep3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Syncing device info…"
                            android:textSize="13sp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/colorTextTertiary" />

                        <TextView
                            android:id="@+id/tvStep4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Ready"
                            android:textSize="13sp"
                            android:paddingTop="4dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/colorTextTertiary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
