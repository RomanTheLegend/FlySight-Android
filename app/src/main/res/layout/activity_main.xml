<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FlySight 2"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Manager"
            android:textSize="14sp"
            android:textColor="@color/colorTextSecondary" />

    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ── MY DEVICES ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MY DEVICES"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextTertiary"
                android:letterSpacing="0.1"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Ready: device identity + battery -->
                    <LinearLayout
                        android:id="@+id/panelDeviceReady"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- Identity row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="12dp">

                            <ImageView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:src="@drawable/ic_device"
                                android:scaleType="fitCenter" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/tvDeviceName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/colorTextPrimary" />

                                <TextView
                                    android:id="@+id/tvDeviceMac"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="12sp"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/colorTextSecondary" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● PAIRED"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorPrimary" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:background="@color/colorElevated" />

                        <!-- Battery row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_battery"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BATTERY"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:textColor="@color/colorTextTertiary"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="12dp" />

                            <ProgressBar
                                android:id="@+id/batteryProgress"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="@color/colorPrimary"
                                android:progressBackgroundTint="@color/colorElevated" />

                            <TextView
                                android:id="@+id/tvBatteryPct"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--%"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorTextPrimary"
                                android:layout_marginStart="12dp"
                                android:minWidth="42dp"
                                android:gravity="end" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Connecting: progress steps -->
                    <LinearLayout
                        android:id="@+id/panelDeviceConnecting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvConnectDevice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/colorTextSecondary"
                            android:paddingTop="12dp"
                            android:paddingBottom="10dp" />

                        <ProgressBar
                            android:id="@+id/progressBarConnect"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/colorDownload"
                            android:layout_marginStart="-16dp"
                            android:layout_marginEnd="-16dp" />

                        <TextView
                            android:id="@+id/tvStep1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Pairing handshake"
                            android:textSize="13sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/colorTextTertiary" />

                        <TextView
                            android:id="@+id/tvStep2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Authenticating"
                            android:textSize="13sp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/colorTextTertiary" />

                        <TextView
                            android:id="@+id/tvStep3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Syncing device info…"
                            android:textSize="13sp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/colorTextTertiary" />

                        <TextView
                            android:id="@+id/tvStep4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Ready"
                            android:textSize="13sp"
                            android:paddingTop="4dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/colorTextTertiary" />

                    </LinearLayout>

                    <!-- Disconnected: paired devices list -->
                    <LinearLayout
                        android:id="@+id/panelDeviceList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerPaired"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <TextView
                            android:id="@+id/tvNoPaired"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No paired devices. Connect to a FlySight 2 to add it here."
                            android:textColor="@color/colorTextTertiary"
                            android:textSize="13sp"
                            android:padding="16dp"
                            android:visibility="visible" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── ACTIONS ─────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/sectionActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACTIONS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextTertiary"
                    android:letterSpacing="0.1"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp" />

                <!-- View track -->
                <LinearLayout
                    android:id="@+id/btnViewTrack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_btn_action"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="8dp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_action_view_track"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View track"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Browse recorded jumps"
                            android:textSize="12sp"
                            android:textColor="@color/colorTextSecondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Score track -->
                <LinearLayout
                    android:id="@+id/btnScoreTrack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_btn_action"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="8dp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_action_score_track"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Score track"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analyse jump performance"
                            android:textSize="12sp"
                            android:textColor="@color/colorTextSecondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Compare tracks -->
                <LinearLayout
                    android:id="@+id/btnCompareTracks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_btn_action"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="8dp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_action_compare_tracks"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compare tracks"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Overlay two or more jumps"
                            android:textSize="12sp"
                            android:textColor="@color/colorTextSecondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- FlySight settings -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_btn_action"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="8dp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_action_settings"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FlySight settings"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit device configuration"
                            android:textSize="12sp"
                            android:textColor="@color/colorTextSecondary" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ── ADD NEW DEVICE ──────────────────────────────────── -->
            <TextView
                android:id="@+id/tvSectionAddDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ADD NEW DEVICE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextTertiary"
                android:letterSpacing="0.1"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Idle: hint + scan button -->
                    <LinearLayout
                        android:id="@+id/panelScanIdle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Turn off your FlySight and press the Power button twice to enter pairing mode. The green LED will start pulsing."
                            android:textSize="13sp"
                            android:textColor="@color/colorTextSecondary"
                            android:paddingBottom="14dp" />

                        <LinearLayout
                            android:id="@+id/btnScan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_btn_action"
                            android:padding="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:src="@drawable/ic_scan"
                                android:scaleType="fitCenter"
                                android:layout_marginEnd="12dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvBtnScanLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Scan for devices"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/colorTextPrimary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Find FlySights in pairing mode"
                                    android:textSize="12sp"
                                    android:textColor="@color/colorTextSecondary" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Scanning: status + results -->
                    <LinearLayout
                        android:id="@+id/panelScanActive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Scanning for devices…"
                                android:textSize="13sp"
                                android:textColor="@color/colorTextSecondary" />

                            <TextView
                                android:id="@+id/tvScanCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorPrimary" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/colorPrimary" />

                        <TextView
                            android:id="@+id/tvEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No FlySight 2 devices found.\nMake sure the device is powered on."
                            android:textColor="@color/colorTextSecondary"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:visibility="gone" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Disconnect — pinned at bottom, only visible when Ready -->
    <LinearLayout
        android:id="@+id/btnDisconnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_btn_danger"
        android:padding="10dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_disconnect"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disconnect"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="End current session"
                android:textSize="12sp"
                android:textColor="@color/colorTextSecondary" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
